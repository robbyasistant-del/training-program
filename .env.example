# Environment variables - COPY THIS FILE TO .env AND FILL IN YOUR VALUES

# PostgreSQL connection
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/training_program?schema=public"

# Strava API credentials - Get from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
STRAVA_REDIRECT_URI=http://localhost:4004/api/auth/strava/callback

# Token encryption key - Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your_64_char_hex_key

# Next.js
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:4004
