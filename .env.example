# ============================================
# Strava OAuth Configuration
# ============================================
# Obtener credenciales en: https://www.strava.com/settings/api
STRAVA_CLIENT_ID=tu_strava_client_id
STRAVA_CLIENT_SECRET=tu_strava_client_secret

# URL de callback (debe coincidir con la configurada en Strava)
STRAVA_REDIRECT_URI=http://localhost:4004/api/auth/strava/callback

# ============================================
# Token Encryption
# ============================================
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Debe ser exactamente 64 caracteres hexadecimales (32 bytes)
TOKEN_ENCRYPTION_KEY=tu_clave_de_64_caracteres_hex_aqui

# ============================================
# Cron Job Security (opcional pero recomendado)
# ============================================
# Usado para proteger el endpoint de cron jobs
CRON_SECRET=tu_cron_secret_aqui

# ============================================
# Database
# ============================================
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/training_program

# ============================================
# App Configuration
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:4004
NODE_ENV=development
