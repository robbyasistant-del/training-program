    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "next": "14.2.35",
    "node-cron": "^3.0.3",
    "pg": "^8.20.0",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.1",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
